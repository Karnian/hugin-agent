{
  "name": "@contextualai/hugin-agent",
  "version": "0.0.0",
  "description": "Hugin Agent — outbound-only local bridge daemon that runs headless Claude Code / Codex CLI for a cloud orchestrator, without opening inbound ports.",
  "type": "module",
  "bin": {
    "hugind": "./dist/cli.js"
  },
  "files": [
    "dist",
    "service"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "protocol:check": "tsx protocol/v1/selftest.ts",
    "pairing:check": "tsx protocol/v1/pairing-selftest.ts",
    "pairing:gen": "tsx protocol/v1/gen-pairing-vectors.ts",
    "spike:approval": "tsx spikes/approval-prompt-tool/run.ts",
    "hugind": "tsx src/index.ts",
    "hugind:start": "tsx src/cli.ts start",
    "hugind:stop": "tsx src/cli.ts stop",
    "hugind:status": "tsx src/cli.ts status",
    "hugind:restart": "tsx src/cli.ts restart",
    "connect": "tsx src/connect.ts",
    "mock-relay": "tsx mock-relay/server.ts",
    "mock-pairing": "tsx scripts/mock-pairing.ts",
    "e2e": "tsx scripts/e2e.ts",
    "e2e:claude": "tsx scripts/e2e-claude.ts"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.3.0",
    "better-sqlite3": "^12.11.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "tsup": "8.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
